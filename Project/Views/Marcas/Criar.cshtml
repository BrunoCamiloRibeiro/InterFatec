@model FabysUnha.ViewModels.MarcasViewModel

<h1>Criar Marca</h1>

<hr />

<form asp-action="Criar" method="post">
    <div>
        <label asp-for="Nome">Nome da Marca:</label>
        <input asp-for="Nome" />
        <span asp-validation-for="Nome"></span>
    </div>
    
    <br />
    
    <div>
        <button type="submit">Salvar</button>
    </div>
</form>

<br />

<div>
    <a asp-action="Index">Voltar para a lista</a>
</div>