@model ServicoDetalhesViewModel

<h1>Detalhes do serviço</h1>

<p><strong>Id:</strong> @Model.Id</p>
<p><strong>Descrição:</strong> @Model.Descricao</p>
<p><strong>Preço:</strong> @Model.PrecoFormatado</p>
<p><strong>Tempo:</strong> @Model.TempoFormatado</p>
<p><strong>Status:</strong> @Model.Status</p>

<p>
    <a asp-action="Editar" asp-route-id="@Model.Id">Editar</a>
    <a asp-action="Index">Voltar</a>
</p>