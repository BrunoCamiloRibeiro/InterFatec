@model FuncionarioDetalhesViewModel

<h1>Detalhes do funcionário</h1>

<p><strong>Id:</strong> @Model.Id</p>
<p><strong>Nome:</strong> @Model.Nome</p>
<p><strong>Telefone:</strong> @Model.Telefone</p>
<p><strong>Status:</strong> @Model.Status</p>
<p><strong>Salário:</strong> @Model.Salario</p>
<p><strong>Especialidade:</strong> @Model.EspecialidadeNome</p>
<p><strong>Serviços agendados:</strong> @Model.ServicosAgendados.Count</p>

<p>
    <a asp-action="Editar" asp-route-id="@Model.Id">Editar</a>
    <a asp-action="Index">Voltar</a>
</p>